# ══════════════════════════════════════════════════
# WorkinFlow MOM — Environment Variables
# Copy to .env and fill in your values
# ══════════════════════════════════════════════════

# ── Database (PostgreSQL) ─────────────────────────
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/workinflow_mom?schema=public"

# ── Auth (NextAuth v5) ────────────────────────────
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://mom.workinflow.cloud"
AUTH_TRUST_HOST="true"

# ── Super Admin (separate JWT) ────────────────────
# generate-with-openssl-rand-base64-32 — MUST differ from AUTH_SECRET
SA_JWT_SECRET=""

# ── SaaS URLs (shown in emails, redirects) ────────
NEXT_PUBLIC_APP_URL="https://mom.workinflow.cloud"
NEXT_PUBLIC_LANDING_URL="https://workinflow.cloud"
NEXT_PUBLIC_SA_URL="https://admin.workinflow.cloud"

# ── Factory Board (public TV display) ─────────────
FACTORY_BOARD_TOKEN="workinflow-factory-2026"

# ── Email (Resend) ────────────────────────────────
# Get from https://resend.com/api-keys — optional (graceful no-op if unset)
RESEND_API_KEY=""
RESEND_FROM_ADDRESS="WorkinFlow <noreply@workinflow.cloud>"

# Note: Platform Issuer (ใบกำกับภาษีค่าบริการ SaaS) is managed in the DB
# via the super admin panel at /superadmin/settings — no env vars needed.

# ── Payment: Omise (PromptPay QR + card) ──────────
# Get from https://dashboard.omise.co — optional
OMISE_PUBLIC_KEY=""
OMISE_SECRET_KEY=""
OMISE_WEBHOOK_SECRET=""

# ── Payment: SlipOK (PromptPay slip verification) ─
# Get from https://slipok.com — optional
SLIPOK_API_KEY=""
SLIPOK_BRANCH_ID=""

# ── Object Storage: Cloudflare R2 (WHT cert files) ─
# Dashboard: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
# Create a User API Token (S3-compat credentials) for the bucket.
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ENDPOINT=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET="workinflow-wht-certs"

# ── Cron / Scheduled Tasks (Phase 6B automation) ──
# Shared secret for /api/cron/* endpoints. Coolify scheduled task must send
# this as the `x-cron-secret` header. If unset, cron endpoints are open
# (dev only — never ship to prod without setting this).
# generate-with-openssl-rand-base64-32
CRON_SECRET=""

# ── Optional ──────────────────────────────────────
# NODE_ENV="production"
