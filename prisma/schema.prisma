generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ══════════════════════════════════════════════════
// MULTI-TENANCY + SaaS
// ══════════════════════════════════════════════════

enum TenantStatus {
  TRIAL // ช่วงทดลองใช้
  ACTIVE // สมัครแล้ว / จ่ายแล้ว
  SUSPENDED // ถูกระงับชั่วคราว (อ่านอย่างเดียว)
  CANCELLED // ยกเลิก
}

/// ประเภทนิติบุคคล / บุคคลธรรมดา (ตามรูปแบบกรมพัฒนาธุรกิจการค้า)
enum JuristicType {
  COMPANY_LTD // บริษัทจำกัด
  PUBLIC_CO // บริษัทมหาชนจำกัด
  LIMITED_PARTNERSHIP // ห้างหุ้นส่วนจำกัด
  FOUNDATION // มูลนิธิ
  ASSOCIATION // สมาคม
  JOINT_VENTURE // กิจการร่วมค้า
  OTHER_JURISTIC // นิติบุคคลอื่น ๆ
  INDIVIDUAL // บุคคลธรรมดา
}

model Tenant {
  id           String        @id @default(cuid())
  name         String // ชื่อบริษัท
  code         String        @unique // e.g. "WF01" — prefix doc numbering
  slug         String?       @unique // e.g. "workinflow" — สำหรับ URL / SA อ้างอิง
  taxId        String? // เลขผู้เสียภาษีบริษัท
  branchNo     String? // เลขสาขา (HQ = "00000", สาขา = "00001" ...)
  juristicType JuristicType? // ประเภทนิติบุคคล
  country      String        @default("TH") // รหัสประเทศ ISO 3166-1 alpha-2
  address      String? // ที่อยู่บริษัท (สำหรับใบกำกับภาษี)
  phone        String?
  email        String?
  logo         String? // URL โลโก้
  vatRate      Decimal       @default(7) @db.Decimal(5, 2) // อัตรา VAT %
  // Subscription state
  status       TenantStatus  @default(TRIAL)
  trialEndsAt  DateTime? // วันที่ทดลองใช้หมด
  planId       String? // FK → Plan
  plan         Plan?         @relation(fields: [planId], references: [id])
  // Activity tracking
  lastActiveAt DateTime?
  onboardedAt  DateTime? // เมื่อ tenant ทำ onboarding เสร็จ
  isActive     Boolean       @default(true) // เก็บไว้เพื่อ backward compat
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  users                User[]
  customers            Customer[]
  products             Product[]
  materials            Material[]
  consumables          Consumable[]
  cncMachines          CncMachine[]
  quotations           Quotation[]
  salesOrders          SalesOrder[]
  invoices             Invoice[]
  taxInvoices          TaxInvoice[]
  receipts             Receipt[]
  creditNotes          CreditNote[]
  payments             Payment[]
  productionPlans      ProductionPlan[]
  workOrders           WorkOrder[]
  purchaseOrders       PurchaseOrder[]
  documentSequences    DocumentSequence[]
  subscriptions        Subscription[]
  subscriptionInvoices SubscriptionInvoice[]

  @@index([status])
  @@index([planId])
}

// ══════════════════════════════════════════════════
// PLANS & SUBSCRIPTIONS (SaaS)
// ══════════════════════════════════════════════════

enum PlanTier {
  FREE
  STARTER
  PRO
  ENTERPRISE
  CUSTOM
}

model Plan {
  id                      String   @id @default(cuid())
  tier                    PlanTier @default(FREE)
  slug                    String   @unique // "free", "starter", "pro", "enterprise"
  name                    String // "Free", "Starter", "Professional", "Enterprise"
  description             String?
  // Pricing (satang — 1 THB = 100 satang)
  priceMonthly            Int      @default(0) // satang / เดือน
  priceYearly             Int      @default(0) // satang / ปี
  yearlyDiscountPercent   Int      @default(0) // e.g. 16 = 16% off when paying yearly
  // Usage limits (0 = unlimited)
  maxUsers                Int      @default(0)
  maxMachines             Int      @default(0)
  maxCustomers            Int      @default(0)
  maxProducts             Int      @default(0)
  maxWorkOrdersPerMonth   Int      @default(0)
  // Feature flags
  featureProduction       Boolean  @default(true) // Work Orders, BOM, Planning
  featureFinance          Boolean  @default(true) // Invoices, Tax Invoices, Receipts
  featureMaintenance      Boolean  @default(false)
  featureFactoryDashboard Boolean  @default(false) // Public TV dashboard
  featureAuditLog         Boolean  @default(false)
  featurePurchaseOrders   Boolean  @default(true)
  featureAdvancedReports  Boolean  @default(false)
  featureExcelExport      Boolean  @default(false)
  featureCustomBranding   Boolean  @default(false) // remove WorkinFlow branding
  featureApiAccess        Boolean  @default(false) // external API
  featureMultiLocation    Boolean  @default(false)
  // Metadata
  sortOrder               Int      @default(0) // display order on pricing page
  isPublic                Boolean  @default(true) // false = hidden (for CUSTOM per-tenant plans)
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  tenants       Tenant[]
  subscriptions Subscription[]

  @@index([tier])
}

enum SubscriptionStatus {
  TRIAL
  PENDING // สร้างแล้วรอชำระเงิน
  ACTIVE // จ่ายแล้ว
  EXPIRED // หมดอายุ
  CANCELLED
  SUSPENDED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum PaymentGateway {
  OMISE
  SLIPOK
  MANUAL
}

model Subscription {
  id             String             @id @default(cuid())
  tenantId       String
  tenant         Tenant             @relation(fields: [tenantId], references: [id])
  planId         String
  plan           Plan               @relation(fields: [planId], references: [id])
  status         SubscriptionStatus @default(PENDING)
  billingCycle   BillingCycle       @default(MONTHLY)
  periodStart    DateTime
  periodEnd      DateTime
  // Amount (satang)
  amountSatang   Int // subtotal
  discountSatang Int                @default(0)
  vatSatang      Int // VAT 7%
  totalSatang    Int // amount - discount + vat
  // Payment details
  paymentGateway PaymentGateway?
  omiseChargeId  String?            @unique
  slipUrl        String? // PromptPay slip image
  slipVerifiedAt DateTime?
  gatewayRef     String? // external reference
  // Discount
  discountCodeId String?
  discountCode   DiscountCode?      @relation(fields: [discountCodeId], references: [id])
  // Cancel
  cancelledAt    DateTime?
  cancelReason   String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  invoices SubscriptionInvoice[]

  @@index([tenantId, status])
  @@index([periodEnd])
}

model SubscriptionInvoice {
  id             String       @id @default(cuid())
  invoiceNumber  String       @unique // "WF-SUB-2026-00001"
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  // Snapshot
  tenantName     String
  tenantTaxId    String?
  tenantAddress  String?
  planName       String
  // Amount (satang)
  subtotalSatang Int
  discountSatang Int          @default(0)
  vatSatang      Int
  totalSatang    Int
  // Dates
  issueDate      DateTime     @default(now())
  paidAt         DateTime?
  // File
  pdfUrl         String?
  createdAt      DateTime     @default(now())

  @@index([tenantId])
  @@index([subscriptionId])
}

enum DiscountType {
  PERCENT // ส่วนลดเป็น %
  FIXED // ส่วนลดเป็นจำนวนเงิน (satang)
}

model DiscountCode {
  id               String       @id @default(cuid())
  code             String       @unique
  description      String?
  discountType     DiscountType @default(PERCENT)
  discountValue    Int // percent (1-100) OR satang
  // Restrictions
  validFrom        DateTime?
  validUntil       DateTime?
  maxUses          Int? // total uses across all tenants (null = unlimited)
  usedCount        Int          @default(0)
  maxUsesPerTenant Int? // null = unlimited per tenant
  // Plan restriction (null = all plans)
  allowedPlanIds   String[]     @default([])
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  subscriptions Subscription[]
}

// ══════════════════════════════════════════════════
// USER INVITES (invite by email → accept → set password)
// ══════════════════════════════════════════════════

model UserInvite {
  id             String    @id @default(cuid())
  token          String    @unique // random URL-safe token
  email          String
  name           String? // suggested name (can be edited on accept)
  role           Role      @default(OPERATOR)
  tenantId       String
  invitedById    String // User.id of the inviter
  invitedByName  String // snapshot
  expiresAt      DateTime // default +7 days
  acceptedAt     DateTime?
  acceptedUserId String? // User.id created on accept
  cancelledAt    DateTime?
  createdAt      DateTime  @default(now())

  @@index([tenantId, acceptedAt])
  @@index([email])
}

// ══════════════════════════════════════════════════
// SUPER ADMIN (Platform Operator)
// ══════════════════════════════════════════════════

model SuperAdmin {
  id             String    @id @default(cuid())
  username       String    @unique
  email          String    @unique
  name           String
  hashedPassword String
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

/// Platform-level settings (singleton — id always "SINGLETON").
/// Holds info about the entity that operates WorkinFlow itself,
/// used on SubscriptionInvoice PDFs (ใบกำกับภาษีค่าบริการ SaaS).
/// Edited by super admin at /superadmin/settings; no redeploy needed.
model PlatformSettings {
  id            String   @id @default("SINGLETON")
  issuerName    String   @default("")
  issuerTaxId   String   @default("")
  issuerAddress String   @default("")
  issuerPhone   String   @default("")
  issuerEmail   String   @default("")
  updatedAt     DateTime @updatedAt
  updatedBy     String? // SuperAdmin.id who last saved
}

// ══════════════════════════════════════════════════
// AUTH & RBAC
// ══════════════════════════════════════════════════

enum Role {
  ADMIN
  MANAGER
  PLANNER
  SALES
  OPERATOR
  QC
  ACCOUNTING
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String
  hashedPassword      String
  role                Role      @default(OPERATOR)
  isActive            Boolean   @default(true)
  // Password reset
  resetToken          String?   @unique
  resetTokenExpiresAt DateTime?
  // Email verification
  emailVerifiedAt     DateTime?
  tenantId            String
  tenant              Tenant    @relation(fields: [tenantId], references: [id])
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  quotations    Quotation[]    @relation("QuotationCreatedBy")
  salesOrders   SalesOrder[]   @relation("SOCreatedBy")
  invoices      Invoice[]      @relation("InvoiceCreatedBy")
  receipts      Receipt[]      @relation("ReceiptCreatedBy")
  workOrderLogs WorkOrderLog[]

  @@index([tenantId])
}

// ══════════════════════════════════════════════════
// CUSTOMERS (ลูกค้า)
// ══════════════════════════════════════════════════

enum CustomerType {
  OEM
  DEALER
  END_USER
  OTHER
}

model Customer {
  id                   String        @id @default(cuid())
  code                 String
  name                 String
  customerType         CustomerType  @default(OTHER)
  juristicType         JuristicType? // ประเภทนิติบุคคล / บุคคลธรรมดา
  country              String        @default("TH") // รหัสประเทศ ISO 3166-1 alpha-2
  contactName          String?
  email                String?
  phone                String?
  lineId               String? // LINE ID สำหรับติดต่อ
  taxId                String? // เลขผู้เสียภาษี (สำหรับใบกำกับภาษี)
  branchNo             String? // เลขสาขา (HQ = "00000" หรือว่าง, สาขา = "00001" ...)
  // ที่อยู่ออกบิล
  billingAddress       String?
  // ที่อยู่จัดส่ง (ถ้าต่างจากที่อยู่ออกบิล)
  shippingAddress      String?
  // VAT
  isVatRegistered      Boolean       @default(true) // ลูกค้าจด VAT หรือไม่ — กำหนดว่าออก TI ได้ + ใช้ prefix เอกสารแยก
  // Tax policy (Billing Nature + WHT)
  /// ลูกค้ารายนี้หัก ณ ที่จ่าย 3% หรือไม่ (default false เพราะ base case คือขายสินค้า)
  withholdsTax         Boolean       @default(false)
  /// ประเภทเอกสารเริ่มต้นเวลาออกบิลให้ลูกค้ารายนี้ (GOODS = ขายสินค้า)
  defaultBillingNature BillingNature @default(GOODS)
  // เงื่อนไขการเงิน
  paymentTermDays      Int           @default(30) // เครดิตเทอม (วัน)
  creditLimit          Decimal?      @db.Decimal(14, 2) // วงเงินเครดิต
  isActive             Boolean       @default(true)
  tenantId             String
  tenant               Tenant        @relation(fields: [tenantId], references: [id])
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  contacts    CustomerContact[]
  quotations  Quotation[]
  salesOrders SalesOrder[]
  invoices    Invoice[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model CustomerContact {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String
  position   String? // ตำแหน่ง
  phone      String?
  email      String?
  lineId     String?
  isPrimary  Boolean  @default(false)

  @@index([customerId])
}

// ══════════════════════════════════════════════════
// PRODUCTS (ชิ้นงานสำเร็จรูป)
// ══════════════════════════════════════════════════

model Product {
  id                    String   @id @default(cuid())
  code                  String
  name                  String
  description           String?
  category              String? // e.g. "Bracket", "Mount", "Cover"
  fusionFileName        String? // ชื่อไฟล์แบบ Fusion 360
  fusionFileUrl         String? // link ไปยังไฟล์แบบ
  drawingNotes          String? // หมายเหตุจากแบบ
  requiresPainting      Boolean  @default(false)
  requiresLogoEngraving Boolean  @default(false)
  defaultColor          String?
  defaultSurfaceFinish  String? // e.g. "Anodize", "Bead Blast", "Polish"
  unitPrice             Decimal? @db.Decimal(12, 2) // ราคาอ้างอิง
  cycleTimeMinutes      Decimal? @db.Decimal(8, 2) // เวลาผลิตต่อชิ้น (นาที)
  leadTimeDays          Int      @default(0)
  isActive              Boolean  @default(true)
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id])
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  images              ProductImage[]
  bomLines            BomLine[]            @relation("ProductBom")
  quotationLines      QuotationLine[]
  salesOrderLines     SalesOrderLine[]
  productionPlanLines ProductionPlanLine[]
  workOrders          WorkOrder[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String // /uploads/products/xxx.jpg
  caption   String? // คำอธิบาย เช่น "แบบด้านหน้า", "ชิ้นงานจริง"
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
}

// ══════════════════════════════════════════════════
// MATERIALS (วัตถุดิบ)
// ══════════════════════════════════════════════════

enum MaterialUnit {
  PCS
  KG
  M
  MM
  CM
  SHEET
  BAR
  ROD
  BLOCK
  SET
  BOX
}

model Material {
  id            String       @id @default(cuid())
  code          String
  name          String // e.g. "Aluminium 6061 T6 Round Bar"
  type          String? // e.g. "Aluminium", "Steel", "Brass"
  specification String? // e.g. "6061-T6", "SUS304"
  unit          MaterialUnit @default(PCS)
  dimensions    String? // e.g. "Ø50 x 100mm"
  stockQty      Decimal      @default(0) @db.Decimal(12, 4)
  minStockQty   Decimal      @default(0) @db.Decimal(12, 4)
  unitCost      Decimal?     @db.Decimal(12, 2)
  supplierId    String?
  isActive      Boolean      @default(true)
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  bomLines           BomLine[]
  purchaseOrderLines PurchaseOrderLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ══════════════════════════════════════════════════
// CONSUMABLES (วัสดุสิ้นเปลือง)
// ══════════════════════════════════════════════════

enum ConsumableCategory {
  CUTTING_TOOL // ดอกกัด, endmill, ดอกสว่าน
  COOLANT // น้ำหล่อเย็น, น้ำมัน
  ABRASIVE // กระดาษทราย, หินเจียร
  MEASURING // เครื่องมือวัด
  SAFETY // ถุงมือ, แว่น, อุปกรณ์ความปลอดภัย
  OTHER
}

model Consumable {
  id               String             @id @default(cuid())
  code             String
  name             String // e.g. "Endmill Ø10 4F Carbide"
  category         ConsumableCategory @default(OTHER)
  brand            String? // ยี่ห้อ
  specification    String? // สเปค
  unit             String             @default("PCS") // PCS, L, BOX, SET...
  lastPrice        Decimal?           @db.Decimal(12, 2) // ราคาล่าสุด
  lastSupplier     String? // ซัพพลายเออร์ล่าสุด
  lastPurchaseDate DateTime? // วันที่ซื้อล่าสุด
  stockQty         Decimal            @default(0) @db.Decimal(12, 4)
  minStockQty      Decimal            @default(0) @db.Decimal(12, 4)
  isActive         Boolean            @default(true)
  tenantId         String
  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  purchaseOrderLines PurchaseOrderLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ══════════════════════════════════════════════════
// BOM (Bill of Materials)
// ══════════════════════════════════════════════════

model BomLine {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation("ProductBom", fields: [productId], references: [id])
  materialId     String
  material       Material @relation(fields: [materialId], references: [id])
  qtyPerUnit     Decimal  @db.Decimal(12, 4)
  materialSize   String? // ขนาดวัสดุ เช่น "Ø50 x 100mm"
  materialType   String? // ประเภทวัสดุ เช่น "AL6061-T6"
  piecesPerStock Int? // จำนวนชิ้นที่ได้ต่อวัสดุ 1 หน่วย
  notes          String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([productId])
  @@index([materialId])
}

// ══════════════════════════════════════════════════
// CNC MACHINES
// ══════════════════════════════════════════════════

enum MachineType {
  CNC_MILLING
  CNC_LATHE
  CNC_ROUTER
  CNC_ENGRAVING
  OTHER
}

enum MachineStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  OFFLINE
}

model CncMachine {
  id          String        @id @default(cuid())
  code        String
  name        String
  type        MachineType
  status      MachineStatus @default(AVAILABLE)
  description String?
  isActive    Boolean       @default(true)
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workOrders      WorkOrder[]
  maintenanceLogs MaintenanceLog[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ══════════════════════════════════════════════════
// MAINTENANCE LOG (บันทึกซ่อมบำรุง)
// ══════════════════════════════════════════════════

enum MaintenanceType {
  PREVENTIVE // ซ่อมบำรุงตามแผน
  CORRECTIVE // ซ่อมเมื่อเสีย
  INSPECTION // ตรวจสอบ
  CALIBRATION // สอบเทียบ
}

enum MaintenanceStatus {
  SCHEDULED // กำหนดแล้ว ยังไม่ถึงวัน
  OVERDUE // เลยกำหนดแล้ว ยังไม่ได้ทำ
  IN_PROGRESS // กำลังซ่อม
  COMPLETED // เสร็จแล้ว
}

model MaintenanceLog {
  id            String            @id @default(cuid())
  cncMachineId  String
  cncMachine    CncMachine        @relation(fields: [cncMachineId], references: [id], onDelete: Cascade)
  type          MaintenanceType   @default(CORRECTIVE)
  status        MaintenanceStatus @default(SCHEDULED)
  description   String // รายละเอียดงาน
  performedBy   String? // ช่างที่ซ่อม
  cost          Decimal?          @db.Decimal(12, 2)
  scheduledDate DateTime // วันที่กำหนดทำ
  startDate     DateTime? // วันเริ่มจริง
  endDate       DateTime? // วันเสร็จจริง
  notes         String?
  tenantId      String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([cncMachineId])
  @@index([tenantId])
  @@index([status])
}

// ══════════════════════════════════════════════════
// QUOTATION (ใบเสนอราคา)
// ══════════════════════════════════════════════════

enum QuotationStatus {
  DRAFT
  SENT
  REVISED // แก้ไขแล้วรอส่งอีกครั้ง
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

model Quotation {
  id              String          @id @default(cuid())
  quotationNumber String // QT-2026-00001
  revision        Int             @default(1) // revision tracking
  customerId      String
  customer        Customer        @relation(fields: [customerId], references: [id])
  status          QuotationStatus @default(DRAFT)
  issueDate       DateTime        @default(now())
  validUntil      DateTime
  // เงื่อนไข
  paymentTerms    String? // e.g. "มัดจำ 50%, เครดิต 30 วัน"
  deliveryTerms   String? // e.g. "จัดส่งภายใน 30 วัน"
  leadTimeDays    Int? // lead time โดยประมาณ
  // ยอดเงิน
  subtotal        Decimal         @default(0) @db.Decimal(14, 2) // ยอดก่อน VAT
  discountPercent Decimal         @default(0) @db.Decimal(5, 2) // ส่วนลดรวม %
  discountAmount  Decimal         @default(0) @db.Decimal(14, 2) // ส่วนลดเป็นเงิน
  vatRate         Decimal         @default(7) @db.Decimal(5, 2) // VAT %
  vatAmount       Decimal         @default(0) @db.Decimal(14, 2) // VAT เงิน
  totalAmount     Decimal         @default(0) @db.Decimal(14, 2) // ยอดรวมสุทธิ
  // Billing Nature (ไหลลง SO → Invoice)
  billingNature   BillingNature   @default(GOODS)
  notes           String?
  internalNotes   String? // โน้ตภายใน (ลูกค้าไม่เห็น)
  createdById     String
  createdBy       User            @relation("QuotationCreatedBy", fields: [createdById], references: [id])
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  lines       QuotationLine[]
  salesOrders SalesOrder[]
  attachments DocumentAttachment[] @relation("QuotationAttachments")

  @@unique([tenantId, quotationNumber])
  @@index([tenantId, status])
}

model QuotationLine {
  id              String    @id @default(cuid())
  quotationId     String
  quotation       Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId       String
  product         Product   @relation(fields: [productId], references: [id])
  description     String? // รายละเอียดเพิ่มเติม
  quantity        Decimal   @db.Decimal(12, 4)
  color           String?
  surfaceFinish   String? // e.g. "Anodize Black"
  materialSpec    String? // e.g. "AL6061-T6 Ø50mm"
  unitPrice       Decimal   @db.Decimal(12, 2)
  discountPercent Decimal   @default(0) @db.Decimal(5, 2) // ส่วนลดต่อรายการ %
  lineTotal       Decimal   @db.Decimal(14, 2)
  notes           String?
  sortOrder       Int       @default(0)
  // Drawing source + branding (ใช้ auto-classify billing nature + หลักฐานทางกฎหมาย)
  drawingSource      DrawingSource  @default(TENANT_OWNED)
  lineBillingNature  BillingNature?
  productCode        String?
  drawingRevision    String?
  customerDrawingUrl String?
  customerBranding   Json?

  @@index([quotationId])
}

// ══════════════════════════════════════════════════
// SALES ORDER (ใบสั่งซื้อ)
// ══════════════════════════════════════════════════

enum SalesOrderStatus {
  CONFIRMED
  DEPOSIT_PENDING // รอมัดจำ
  IN_PRODUCTION
  PAINTING
  ENGRAVING
  QC_FINAL
  PACKING
  AWAITING_PAYMENT // รอชำระส่วนที่เหลือ
  SHIPPED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  DEPOSIT_PAID // จ่ายมัดจำแล้ว
  PARTIAL
  PAID
}

model SalesOrder {
  id               String           @id @default(cuid())
  orderNumber      String // SO-2026-00001
  quotationId      String?
  quotation        Quotation?       @relation(fields: [quotationId], references: [id])
  customerId       String
  customer         Customer         @relation(fields: [customerId], references: [id])
  customerPoNumber String? // เลข PO ของลูกค้า
  status           SalesOrderStatus @default(CONFIRMED)
  orderDate        DateTime         @default(now())
  requestedDate    DateTime
  promisedDate     DateTime?
  // ที่อยู่จัดส่ง
  shippingAddress  String?
  // มัดจำ
  depositPercent   Decimal          @default(0) @db.Decimal(5, 2) // มัดจำ %
  depositAmount    Decimal          @default(0) @db.Decimal(14, 2) // มัดจำเป็นเงิน
  depositPaidDate  DateTime? // วันที่ได้รับมัดจำ
  // ยอดเงิน
  subtotal         Decimal          @default(0) @db.Decimal(14, 2)
  discountPercent  Decimal          @default(0) @db.Decimal(5, 2)
  discountAmount   Decimal          @default(0) @db.Decimal(14, 2)
  vatRate          Decimal          @default(7) @db.Decimal(5, 2)
  vatAmount        Decimal          @default(0) @db.Decimal(14, 2)
  totalAmount      Decimal          @default(0) @db.Decimal(14, 2)
  // สถานะชำระเงิน
  paymentStatus    PaymentStatus    @default(UNPAID)
  paymentTerms     String? // e.g. "มัดจำ 50%, ส่วนที่เหลือเครดิต 30 วัน"
  // Billing Nature (snapshot จาก quotation, ใช้กำกับ invoice ที่ออกจาก SO นี้)
  billingNature    BillingNature    @default(GOODS)
  // หมายเหตุ
  notes            String?
  internalNotes    String?
  createdById      String
  createdBy        User             @relation("SOCreatedBy", fields: [createdById], references: [id])
  tenantId         String
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  lines           SalesOrderLine[]
  invoices        Invoice[]
  payments        Payment[]
  productionPlans ProductionPlan[]
  attachments     DocumentAttachment[] @relation("SalesOrderAttachments")

  @@unique([tenantId, orderNumber])
  @@index([tenantId, status])
  @@index([tenantId, paymentStatus])
}

model SalesOrderLine {
  id              String     @id @default(cuid())
  salesOrderId    String
  salesOrder      SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product    @relation(fields: [productId], references: [id])
  description     String?
  quantity        Decimal    @db.Decimal(12, 4)
  color           String?
  surfaceFinish   String?
  materialSpec    String?
  unitPrice       Decimal    @db.Decimal(12, 2)
  discountPercent Decimal    @default(0) @db.Decimal(5, 2)
  lineTotal       Decimal    @db.Decimal(14, 2)
  deliveredQty    Decimal    @default(0) @db.Decimal(12, 4) // จำนวนที่ส่งแล้ว
  notes           String?
  sortOrder       Int        @default(0)
  // Drawing source + branding (inherit จาก quotation line, ไหลลง invoice line)
  drawingSource      DrawingSource  @default(TENANT_OWNED)
  lineBillingNature  BillingNature?
  productCode        String?
  drawingRevision    String?
  customerDrawingUrl String?
  customerBranding   Json?

  productionPlanLines ProductionPlanLine[]
  invoiceLines        InvoiceLine[]

  @@index([salesOrderId])
}

// ══════════════════════════════════════════════════
// INVOICE (ใบแจ้งหนี้ / ใบวางบิล)
// ══════════════════════════════════════════════════

enum InvoiceType {
  DEPOSIT // ใบแจ้งหนี้มัดจำ
  FULL // ใบแจ้งหนี้เต็มจำนวน
  REMAINING // ใบแจ้งหนี้ส่วนที่เหลือ (หัก deposit)
  PARTIAL // ใบแจ้งหนี้บางส่วน (แบ่งส่ง)
}

enum InvoiceStatus {
  DRAFT
  ISSUED // ออกแล้ว
  SENT // ส่งลูกค้าแล้ว
  PARTIALLY_PAID
  PAID
  OVERDUE // เลยกำหนดชำระ
  CANCELLED
}

// ══════════════════════════════════════════════════
// BILLING NATURE & WHT (ขายสินค้า vs รับจ้างทำของ)
// ══════════════════════════════════════════════════

/// ประเภทธรรมชาติของบิล — มีผลต่อ PDF wording และ WHT workflow
/// GOODS = ขายสินค้า (default, ไม่หัก ณ ที่จ่าย)
/// MANUFACTURING_SERVICE = รับจ้างทำของ (ลูกค้าหัก 3% ตามประมวลรัษฎากร ม.3 เตรส)
/// MIXED = ผสม (ต้องระบุ nature ต่อ line item)
enum BillingNature {
  GOODS
  MANUFACTURING_SERVICE
  MIXED
}

/// แหล่งที่มาของแบบงาน — ใช้ auto-suggest billing nature
/// TENANT_OWNED = tenant ออกแบบเอง (default) → GOODS
/// CUSTOMER_PROVIDED = ลูกค้าเอาแบบมา → MANUFACTURING_SERVICE
/// JOINT_DEVELOPMENT = ร่วมพัฒนา (grey area, ดู contract)
enum DrawingSource {
  TENANT_OWNED
  CUSTOMER_PROVIDED
  JOINT_DEVELOPMENT
}

/// สถานะหนังสือรับรองหัก ณ ที่จ่าย (50 ทวิ) ต่อ invoice/receipt
enum WhtCertStatus {
  NOT_APPLICABLE // ไม่เข้าข่าย (goods + ไม่ถูกหัก)
  PENDING // ลูกค้าหักแล้วแต่ยังไม่ออก cert
  RECEIVED // รับ cert แล้ว
  VERIFIED // ตรวจสอบเลข/ยอดถูกต้อง
  MISSING_OVERDUE // เลยกำหนดนาน → flag เตือน
}

model Invoice {
  id                      String        @id @default(cuid())
  invoiceNumber           String // INV-2026-00001
  invoiceType             InvoiceType   @default(FULL)
  salesOrderId            String
  salesOrder              SalesOrder    @relation(fields: [salesOrderId], references: [id])
  customerId              String
  customer                Customer      @relation(fields: [customerId], references: [id])
  status                  InvoiceStatus @default(DRAFT)
  issueDate               DateTime      @default(now())
  dueDate                 DateTime // วันครบกำหนดชำระ
  // Snapshot ข้อมูลลูกค้า ณ วันออกเอกสาร
  snapshotCustomerName    String? // ชื่อลูกค้า ณ วันออก
  snapshotCustomerAddress String? // ที่อยู่ ณ วันออก
  snapshotCustomerTaxId   String? // เลขภาษี ณ วันออก
  // ยอดเงิน
  subtotal                Decimal       @default(0) @db.Decimal(14, 2)
  discountAmount          Decimal       @default(0) @db.Decimal(14, 2)
  vatRate                 Decimal       @default(7) @db.Decimal(5, 2)
  vatAmount               Decimal       @default(0) @db.Decimal(14, 2)
  totalAmount             Decimal       @default(0) @db.Decimal(14, 2)
  paidAmount              Decimal       @default(0) @db.Decimal(14, 2)
  // Billing nature + Withholding Tax (3% ม.3 เตรส)
  billingNature           BillingNature @default(GOODS)
  whtRate                 Decimal       @default(0) @db.Decimal(5, 2) // อัตรา WHT % (0=ไม่หัก, 3=หัก 3%)
  whtAmount               Decimal       @default(0) @db.Decimal(14, 2) // ยอด WHT ที่ลูกค้าหัก
  whtCertNumber           String? // เลขหนังสือรับรองหัก ณ ที่จ่าย (50 ทวิ)
  whtCertReceivedAt       DateTime? // วันรับ cert
  whtCertFileUrl          String? // ไฟล์ scan cert
  whtCertStatus           WhtCertStatus @default(NOT_APPLICABLE)
  // ยกเลิก
  cancelledAt             DateTime?
  cancelledById           String?
  cancelReason            String? // เหตุผลที่ยกเลิก
  // หมายเหตุ
  notes                   String?
  createdById             String
  createdBy               User          @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  tenantId                String
  tenant                  Tenant        @relation(fields: [tenantId], references: [id])
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  lines       InvoiceLine[]
  taxInvoices TaxInvoice[]
  receipts    Receipt[]
  payments    Payment[]
  creditNotes CreditNote[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([tenantId, whtCertStatus]) // สำหรับ WHT tracking dashboard
}

model InvoiceLine {
  id                 String          @id @default(cuid())
  invoiceId          String
  invoice            Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  salesOrderLineId   String?
  salesOrderLine     SalesOrderLine? @relation(fields: [salesOrderLineId], references: [id])
  description        String // รายละเอียดรายการ
  quantity           Decimal         @db.Decimal(12, 4)
  unitPrice          Decimal         @db.Decimal(12, 2)
  lineTotal          Decimal         @db.Decimal(14, 2)
  notes              String?
  sortOrder          Int             @default(0)
  // Drawing source + branding (ใช้ auto-classify billing nature + เป็นหลักฐานทางกฎหมาย)
  /// แหล่งที่มาของแบบ: tenant ออกเอง (default) / ลูกค้าเอามา / ร่วมพัฒนา
  drawingSource      DrawingSource   @default(TENANT_OWNED)
  /// Override billing nature ต่อ line — ใช้เมื่อ invoice ตัวแม่เป็น MIXED
  lineBillingNature  BillingNature?
  /// Product SKU/code (จาก catalog ของ tenant) — หลักฐานว่ามี product master
  productCode        String?
  /// Drawing revision เช่น "REV-A-2026" — หลักฐาน design ownership
  drawingRevision    String?
  /// ไฟล์แบบจากลูกค้า (ถ้า drawingSource = CUSTOMER_PROVIDED)
  customerDrawingUrl String?
  /// OEM Branding spec: { logoUrl, markingMethod, position, ... } — spec ของลูกค้าที่ tenant ผลิต
  customerBranding   Json?

  @@index([invoiceId])
}

// ══════════════════════════════════════════════════
// TAX INVOICE (ใบกำกับภาษี)
// ══════════════════════════════════════════════════

enum TaxInvoiceStatus {
  DRAFT
  ISSUED
  CANCELLED
}

model TaxInvoice {
  id               String           @id @default(cuid())
  taxInvoiceNumber String // TI-2026-00001
  invoiceId        String
  invoice          Invoice          @relation(fields: [invoiceId], references: [id])
  status           TaxInvoiceStatus @default(DRAFT)
  issueDate        DateTime         @default(now())
  // ข้อมูลผู้ซื้อ (snapshot ณ วันออก)
  buyerName        String
  buyerTaxId       String?
  buyerAddress     String?
  buyerBranch      String? // สำนักงานใหญ่ / สาขา
  // ข้อมูลผู้ขาย (snapshot ณ วันออก)
  sellerName       String
  sellerTaxId      String?
  sellerAddress    String?
  // ยอดเงิน
  subtotal         Decimal          @default(0) @db.Decimal(14, 2)
  vatRate          Decimal          @default(7) @db.Decimal(5, 2)
  vatAmount        Decimal          @default(0) @db.Decimal(14, 2)
  totalAmount      Decimal          @default(0) @db.Decimal(14, 2)
  // Billing nature snapshot (ณ วันออก TI) — ต้อง preserve เพราะ PDF wording อ้างจากค่านี้
  billingNature    BillingNature    @default(GOODS)
  // ยกเลิก
  cancelledAt      DateTime?
  cancelledById    String?
  cancelReason     String?
  notes            String?
  tenantId         String
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([tenantId, taxInvoiceNumber])
  @@index([tenantId])
}

// ══════════════════════════════════════════════════
// RECEIPT (ใบเสร็จรับเงิน)
// ══════════════════════════════════════════════════

enum ReceiptStatus {
  DRAFT
  ISSUED
  CANCELLED
}

model Receipt {
  id            String        @id @default(cuid())
  receiptNumber String // RC-2026-00001
  invoiceId     String
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  paymentId     String?
  payment       Payment?      @relation(fields: [paymentId], references: [id])
  status        ReceiptStatus @default(DRAFT)
  issueDate     DateTime      @default(now())
  // ยอดเงินที่รับ (net of WHT)
  amount        Decimal       @db.Decimal(14, 2)
  // Billing nature snapshot (ณ วันออก receipt)
  billingNature BillingNature @default(GOODS)
  // WHT ที่ลูกค้าหัก ณ ที่จ่าย (ถ้ามี) — net = grossAmount - whtAmount
  grossAmount   Decimal?      @db.Decimal(14, 2) // ยอดก่อนหัก ณ ที่จ่าย
  whtRate       Decimal       @default(0) @db.Decimal(5, 2)
  whtAmount     Decimal       @default(0) @db.Decimal(14, 2)
  whtCertNumber     String? // เลข 50 ทวิ (ถ้ารับมาตอนออก receipt)
  whtCertReceivedAt DateTime? // วันรับ cert
  whtCertFileUrl    String? // ไฟล์ scan cert (R2 object key)
  whtCertStatus     WhtCertStatus @default(NOT_APPLICABLE)
  // รายละเอียดผู้จ่าย (snapshot)
  payerName     String
  payerTaxId    String?
  payerAddress  String?
  // ยกเลิก
  cancelledAt   DateTime?
  cancelledById String?
  cancelReason  String?
  notes         String?
  createdById   String
  createdBy     User          @relation("ReceiptCreatedBy", fields: [createdById], references: [id])
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([tenantId, receiptNumber])
  @@index([tenantId])
}

// ══════════════════════════════════════════════════
// CREDIT NOTE (ใบลดหนี้)
// ══════════════════════════════════════════════════

enum CreditNoteStatus {
  DRAFT
  ISSUED
  APPLIED // หักกับ Invoice แล้ว
  CANCELLED
}

enum CreditNoteReason {
  DEFECTIVE // สินค้าชำรุด
  RETURN // คืนสินค้า
  OVERCHARGE // คิดเกิน
  DISCOUNT // ส่วนลดเพิ่มเติม
  OTHER
}

model CreditNote {
  id                String           @id @default(cuid())
  creditNoteNumber  String // CN-2026-00001
  invoiceId         String
  invoice           Invoice          @relation(fields: [invoiceId], references: [id])
  status            CreditNoteStatus @default(DRAFT)
  reason            CreditNoteReason @default(OTHER)
  issueDate         DateTime         @default(now())
  // ยอดเงิน
  subtotal          Decimal          @default(0) @db.Decimal(14, 2)
  vatRate           Decimal          @default(7) @db.Decimal(5, 2)
  vatAmount         Decimal          @default(0) @db.Decimal(14, 2)
  totalAmount       Decimal          @default(0) @db.Decimal(14, 2)
  // Billing nature snapshot + WHT reversal (ถ้า invoice ต้นฉบับโดนหัก)
  billingNature     BillingNature    @default(GOODS)
  whtReversalAmount Decimal          @default(0) @db.Decimal(14, 2) // ยอด WHT ที่ต้อง reverse กลับ (prorate)
  description       String // เหตุผลที่ลดหนี้
  // ยกเลิก
  cancelledAt       DateTime?
  cancelledById     String?
  cancelReason      String?
  notes             String?
  tenantId          String
  tenant            Tenant           @relation(fields: [tenantId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  lines CreditNoteLine[]

  @@unique([tenantId, creditNoteNumber])
  @@index([tenantId])
}

model CreditNoteLine {
  id           String     @id @default(cuid())
  creditNoteId String
  creditNote   CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  description  String
  quantity     Decimal    @db.Decimal(12, 4)
  unitPrice    Decimal    @db.Decimal(12, 2)
  lineTotal    Decimal    @db.Decimal(14, 2)
  sortOrder    Int        @default(0)

  @@index([creditNoteId])
}

// ══════════════════════════════════════════════════
// PAYMENT (บันทึกการชำระเงิน)
// ══════════════════════════════════════════════════

enum PaymentMethod {
  BANK_TRANSFER // โอนเงิน
  CASH // เงินสด
  CHEQUE // เช็ค
  CREDIT_CARD // บัตรเครดิต
  OTHER
}

enum PaymentType {
  DEPOSIT // มัดจำ
  PARTIAL // ชำระบางส่วน
  FINAL // ชำระส่วนที่เหลือ
  FULL // ชำระเต็มจำนวน
}

model Payment {
  id                    String        @id @default(cuid())
  paymentNumber         String // PAY-2026-00001
  salesOrderId          String
  salesOrder            SalesOrder    @relation(fields: [salesOrderId], references: [id])
  invoiceId             String?
  invoice               Invoice?      @relation(fields: [invoiceId], references: [id])
  paymentType           PaymentType
  paymentMethod         PaymentMethod @default(BANK_TRANSFER)
  amount                Decimal       @db.Decimal(14, 2)
  // หัก ณ ที่จ่าย (WHT)
  withholdingTaxPercent Decimal       @default(0) @db.Decimal(5, 2) // WHT %
  withholdingTaxAmount  Decimal       @default(0) @db.Decimal(14, 2) // WHT เงิน
  netAmount             Decimal       @db.Decimal(14, 2) // ยอดสุทธิหลังหัก WHT
  paymentDate           DateTime
  // รายละเอียดการโอน
  bankName              String? // ชื่อธนาคาร
  referenceNumber       String? // เลขอ้างอิงการโอน
  chequeNumber          String? // เลขที่เช็ค
  slipUrl               String? // รูปสลิป
  notes                 String?
  tenantId              String
  tenant                Tenant        @relation(fields: [tenantId], references: [id])
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  receipts Receipt[]

  @@unique([tenantId, paymentNumber])
  @@index([tenantId])
  @@index([salesOrderId])
}

// ══════════════════════════════════════════════════
// DOCUMENT ATTACHMENTS (ไฟล์แนบ)
// ══════════════════════════════════════════════════

model DocumentAttachment {
  id           String      @id @default(cuid())
  fileName     String // ชื่อไฟล์
  fileUrl      String // URL ไฟล์
  fileType     String? // MIME type
  fileSize     Int? // bytes
  // polymorphic relation
  quotationId  String?
  quotation    Quotation?  @relation("QuotationAttachments", fields: [quotationId], references: [id], onDelete: Cascade)
  salesOrderId String?
  salesOrder   SalesOrder? @relation("SalesOrderAttachments", fields: [salesOrderId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())

  @@index([quotationId])
  @@index([salesOrderId])
}

// ══════════════════════════════════════════════════
// PURCHASE ORDER (ใบสั่งซื้อวัสดุ)
// ══════════════════════════════════════════════════

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id              String              @id @default(cuid())
  poNumber        String // PO-2026-00001
  supplierName    String
  supplierContact String?
  status          PurchaseOrderStatus @default(DRAFT)
  orderDate       DateTime            @default(now())
  expectedDate    DateTime?
  receivedDate    DateTime?
  notes           String?
  totalAmount     Decimal             @default(0) @db.Decimal(14, 2)
  tenantId        String
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  lines PurchaseOrderLine[]

  @@unique([tenantId, poNumber])
  @@index([tenantId, status])
}

enum POLineType {
  MATERIAL // วัตถุดิบ
  CONSUMABLE // วัสดุสิ้นเปลือง
  OTHER // อื่นๆ (พิมพ์เอง)
}

model PurchaseOrderLine {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  lineType        POLineType    @default(OTHER)
  materialId      String?
  material        Material?     @relation(fields: [materialId], references: [id])
  consumableId    String?
  consumable      Consumable?   @relation(fields: [consumableId], references: [id])
  description     String
  quantity        Decimal       @db.Decimal(12, 4)
  unit            String        @default("PCS")
  unitCost        Decimal       @db.Decimal(12, 2)
  lineTotal       Decimal       @db.Decimal(14, 2)
  receivedQty     Decimal       @default(0) @db.Decimal(12, 4)
  notes           String?
  sortOrder       Int           @default(0)

  @@index([purchaseOrderId])
}

// ══════════════════════════════════════════════════
// PRODUCTION PLAN (แผนการผลิต)
// ══════════════════════════════════════════════════

enum ProductionPlanStatus {
  DRAFT
  APPROVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ProductionPlan {
  id           String               @id @default(cuid())
  planNumber   String // PP-2026-00001
  salesOrderId String?
  salesOrder   SalesOrder?          @relation(fields: [salesOrderId], references: [id])
  status       ProductionPlanStatus @default(DRAFT)
  plannedStart DateTime
  plannedEnd   DateTime
  notes        String?
  tenantId     String
  tenant       Tenant               @relation(fields: [tenantId], references: [id])
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  lines      ProductionPlanLine[]
  workOrders WorkOrder[]

  @@unique([tenantId, planNumber])
  @@index([tenantId, status])
}

model ProductionPlanLine {
  id               String          @id @default(cuid())
  productionPlanId String
  productionPlan   ProductionPlan  @relation(fields: [productionPlanId], references: [id], onDelete: Cascade)
  productId        String
  product          Product         @relation(fields: [productId], references: [id])
  salesOrderLineId String?
  salesOrderLine   SalesOrderLine? @relation(fields: [salesOrderLineId], references: [id])
  plannedQty       Decimal         @db.Decimal(12, 4)
  color            String?
  notes            String?
  sortOrder        Int             @default(0)

  @@index([productionPlanId])
}

// ══════════════════════════════════════════════════
// WORK ORDER (ใบสั่งผลิต)
// ══════════════════════════════════════════════════

enum WorkOrderStatus {
  PENDING
  RELEASED
  IN_PROGRESS
  QC_MACHINING
  SENT_TO_PAINTING
  PAINTING_DONE
  ENGRAVING
  QC_FINAL
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum WorkOrderPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum MaterialReadiness {
  READY // วัสดุพร้อมแล้ว (มีอยู่ในสต็อก)
  ORDERED // สั่งแล้วรอของ
  NOT_ORDERED // ยังไม่ได้สั่ง
  PARTIAL // มีบางส่วน
}

model WorkOrder {
  id                   String            @id @default(cuid())
  woNumber             String // WO-2026-00001
  productionPlanId     String?
  productionPlan       ProductionPlan?   @relation(fields: [productionPlanId], references: [id])
  productId            String
  product              Product           @relation(fields: [productId], references: [id])
  cncMachineId         String?
  cncMachine           CncMachine?       @relation(fields: [cncMachineId], references: [id])
  status               WorkOrderStatus   @default(PENDING)
  priority             WorkOrderPriority @default(NORMAL)
  materialStatus       MaterialReadiness @default(NOT_ORDERED) // สถานะวัสดุ
  // Quantities
  plannedQty           Decimal           @db.Decimal(12, 4)
  completedQty         Decimal           @default(0) @db.Decimal(12, 4)
  scrapQty             Decimal           @default(0) @db.Decimal(12, 4)
  // Specifications
  color                String?
  materialSize         String?
  fusionFileName       String?
  // Dates
  plannedStart         DateTime
  plannedEnd           DateTime
  actualStart          DateTime?
  actualEnd            DateTime?
  // Painting outsource
  sentToPaintingDate   DateTime?
  paintingExpectedDate DateTime?
  paintingReceivedDate DateTime?
  paintingVendor       String?
  // Assignment & Scheduling
  assignedTo           String?
  workCenter           String?
  sortOrder            Int               @default(0) // ลำดับบนเครื่อง (timeline drag-drop)
  notes                String?
  tenantId             String
  tenant               Tenant            @relation(fields: [tenantId], references: [id])
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  logs WorkOrderLog[]

  @@unique([tenantId, woNumber])
  @@index([tenantId, status])
  @@index([tenantId, plannedStart])
}

model WorkOrderLog {
  id          String          @id @default(cuid())
  workOrderId String
  workOrder   WorkOrder       @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  fromStatus  WorkOrderStatus
  toStatus    WorkOrderStatus
  qtyReported Decimal?        @db.Decimal(12, 4)
  scrapQty    Decimal?        @db.Decimal(12, 4)
  note        String?
  photoUrl    String?
  createdById String
  createdBy   User            @relation(fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())

  @@index([workOrderId])
}

// ══════════════════════════════════════════════════
// AUDIT LOG (ประวัติการเปลี่ยนแปลง)
// ══════════════════════════════════════════════════

model AuditLog {
  id           String   @id @default(cuid())
  action       String // CREATE, UPDATE, DELETE, STATUS_CHANGE, CANCEL
  entityType   String // Invoice, Quotation, SalesOrder, WorkOrder, etc.
  entityId     String // ID ของเอกสาร
  entityNumber String? // เลขเอกสาร (INV-2026-00001)
  changes      String? // JSON: { field: { from, to } }
  reason       String? // เหตุผล (สำหรับการยกเลิก)
  userId       String
  userName     String // snapshot ชื่อผู้ทำ
  tenantId     String
  createdAt    DateTime @default(now())

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@index([userId])
}

// ══════════════════════════════════════════════════
// ISO DOCUMENT NUMBERING
// ══════════════════════════════════════════════════

// Document prefixes (แยก VAT / non-VAT ชัดเจน):
//   QT  = Quotation (ใบเสนอราคา)
//   SO  = Sales Order (ใบสั่งซื้อ)
//   INV = Invoice VAT (ใบแจ้งหนี้ มี VAT)
//   BIL = Invoice non-VAT (ใบเรียกเก็บเงิน ไม่มี VAT)
//   TI  = Tax Invoice (ใบกำกับภาษี — เฉพาะลูกค้า VAT)
//   RC  = Receipt VAT (ใบเสร็จรับเงิน มี VAT)
//   RN  = Receipt non-VAT (ใบเสร็จรับเงิน ไม่มี VAT)
//   CN  = Credit Note VAT (ใบลดหนี้ มี VAT)
//   CNB = Credit Note non-VAT (ใบลดหนี้ ไม่มี VAT)
//   PAY = Payment (บันทึกชำระเงิน)
//   PP  = Production Plan (แผนการผลิต)
//   WO  = Work Order (ใบสั่งผลิต)
//   PO  = Purchase Order (ใบสั่งซื้อวัสดุ)

model DocumentSequence {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  prefix   String // see prefix list above
  year     Int
  lastSeq  Int    @default(0)

  @@unique([tenantId, prefix, year])
}
